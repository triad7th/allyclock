# See http://help.github.com/ignore-files/ for more about ignoring files.

# compiled output
/dist
/tmp
/out-tsc
/apps/*/dist
# Only exists if Bazel was run
/bazel-out

# dependencies
/node_modules
/apps/*/node_modules
/.worktrees

# profiling files
chrome-profiler-events*.json

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# misc
/.angular/cache
/apps/*/.angular/cache
/.sass-cache
/connect.lock
/coverage
/.netlify
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# Python (asset-generation scripts under assets/app-icon)
__pycache__/
*.pyc

# System Files
.DS_Store
Thumbs.db

# Superpowers brainstorm artifacts
.superpowers/

# Xcode
xcuserdata/
DerivedData/
build/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM
*.xcbkptlist

# Swift Package Manager
.build/
.swiftpm/
Package.resolved
